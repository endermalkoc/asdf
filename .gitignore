# ── Generated knowledge artifacts ──────────────────────────────────────────
# Cusp renders Markdown + HTML from the Dolt DB (the source of truth).
# These are disposable, always-regenerable, and MUST NOT be committed or edited.
/generated/
*.generated.md
*.generated.html

# ── Dolt working database ──────────────────────────────────────────────────
# The knowledge store is its own versioned (Dolt) repo, not tracked by this git repo.
.dolt/

# ── Go build output ────────────────────────────────────────────────────────
# The Go module lives under src/cli/; `make build` still drops the binary here.
/cusp
# a `go build`/`go install` run inside src/cli can drop a binary there too.
/src/cli/cusp
/dist/
*.exe
*.test
*.out
# VSCode / Delve debug binaries
__debug_bin*

# ── VS Code extension (src/extension/) build artifacts ─────────────────────
# node_modules + bundled output are regenerable; the committed dev config
# (src/extension/.vscode/launch.json + tasks.json) is NOT ignored — see below.
node_modules/
src/extension/dist/
src/extension/out/
*.vsix
*.tsbuildinfo

# ── Agent / editor local config ────────────────────────────────────────────
# Personal, machine-local Claude Code settings — never shared. (Shared project
# config like .claude/settings.json IS committable, so don't ignore all of .claude/.)
.claude/settings.local.json

# ── Environment / secrets ──────────────────────────────────────────────────
.env
.env.local

# ── OS / editor ────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
*.swp
.idea/
# Only the repo-root .vscode/ (personal, Go-side settings) is ignored. The VS
# Code extension's own src/extension/.vscode/ is committed — it IS the dev setup.
/.vscode/
