{
  "name": "cusp",
  "displayName": "Cusp",
  "description": "Review Cusp changesets (specs, requirements, plans) inside VS Code.",
  "version": "0.0.1",
  "publisher": "endermalkoc",
  "private": true,
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/endermalkoc/cusp"
  },
  "engines": {
    "vscode": "^1.95.0"
  },
  "categories": [
    "Other"
  ],
  "main": "./dist/extension.js",
  "activationEvents": [
    "onView:cuspChangesets",
    "onView:cuspRequirements",
    "onView:cuspEntities",
    "onView:cuspTests"
  ],
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "cusp",
          "title": "Cusp",
          "icon": "media/cusp.svg"
        }
      ]
    },
    "views": {
      "cusp": [
        {
          "id": "cuspChangesets",
          "name": "Changesets",
          "icon": "media/cusp.svg",
          "contextualTitle": "Cusp Changesets"
        },
        {
          "id": "cuspRequirements",
          "name": "Requirements",
          "icon": "media/cusp.svg",
          "contextualTitle": "Cusp Requirements"
        },
        {
          "id": "cuspEntities",
          "name": "Entities",
          "icon": "media/cusp.svg",
          "contextualTitle": "Cusp Entities"
        },
        {
          "id": "cuspTests",
          "name": "Test",
          "icon": "media/cusp.svg",
          "contextualTitle": "Cusp Tests"
        }
      ]
    },
    "commands": [
      {
        "command": "cusp.refreshChangesets",
        "title": "Refresh Changesets",
        "category": "Cusp",
        "icon": "$(refresh)"
      },
      {
        "command": "cusp.refreshRequirements",
        "title": "Refresh Requirements",
        "category": "Cusp",
        "icon": "$(refresh)"
      },
      {
        "command": "cusp.searchRequirements",
        "title": "Search Requirements",
        "category": "Cusp",
        "icon": "$(search)"
      },
      {
        "command": "cusp.clearRequirementsSearch",
        "title": "Clear Requirements Search",
        "category": "Cusp",
        "icon": "$(close)"
      },
      {
        "command": "cusp.refreshEntities",
        "title": "Refresh Entities",
        "category": "Cusp",
        "icon": "$(refresh)"
      },
      {
        "command": "cusp.refreshTests",
        "title": "Refresh Tests",
        "category": "Cusp",
        "icon": "$(refresh)"
      },
      {
        "command": "cusp.openTestCase",
        "title": "Open Test Case",
        "category": "Cusp"
      },
      {
        "command": "cusp.searchEntities",
        "title": "Search Entities",
        "category": "Cusp",
        "icon": "$(search)"
      },
      {
        "command": "cusp.clearEntitiesSearch",
        "title": "Clear Entities Search",
        "category": "Cusp",
        "icon": "$(close)"
      },
      {
        "command": "cusp.specDocBack",
        "title": "Back",
        "category": "Cusp",
        "icon": "$(arrow-left)",
        "enablement": "cusp.specDocCanGoBack"
      },
      {
        "command": "cusp.specDocForward",
        "title": "Forward",
        "category": "Cusp",
        "icon": "$(arrow-right)",
        "enablement": "cusp.specDocCanGoForward"
      },
      {
        "command": "cusp.reviewChangeset",
        "title": "Review Changeset",
        "category": "Cusp",
        "icon": "$(comment-discussion)"
      },
      {
        "command": "cusp.setVerdict",
        "title": "Set Review Verdict",
        "category": "Cusp",
        "icon": "$(verified)"
      },
      {
        "command": "cusp.review.reply",
        "title": "Add Comment",
        "category": "Cusp"
      },
      {
        "command": "cusp.review.resolveThread",
        "title": "Resolve",
        "category": "Cusp",
        "icon": "$(check)"
      },
      {
        "command": "cusp.review.reopenThread",
        "title": "Reopen",
        "category": "Cusp",
        "icon": "$(comment)"
      },
      {
        "command": "cusp.newChangeset",
        "title": "New Changeset",
        "category": "Cusp",
        "icon": "$(add)"
      },
      {
        "command": "cusp.submitChangeset",
        "title": "Submit for Review",
        "category": "Cusp",
        "icon": "$(check)"
      },
      {
        "command": "cusp.mergeChangeset",
        "title": "Merge into main",
        "category": "Cusp",
        "icon": "$(git-merge)"
      },
      {
        "command": "cusp.abandonChangeset",
        "title": "Abandon Changeset",
        "category": "Cusp",
        "icon": "$(trash)"
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "cusp.newChangeset",
          "when": "view == cuspChangesets",
          "group": "navigation@1"
        },
        {
          "command": "cusp.setVerdict",
          "when": "view == cuspChangesets",
          "group": "navigation@2"
        },
        {
          "command": "cusp.refreshChangesets",
          "when": "view == cuspChangesets",
          "group": "navigation@3"
        },
        {
          "command": "cusp.searchRequirements",
          "when": "view == cuspRequirements",
          "group": "navigation@1"
        },
        {
          "command": "cusp.clearRequirementsSearch",
          "when": "view == cuspRequirements && cusp.requirementsFiltered",
          "group": "navigation@2"
        },
        {
          "command": "cusp.refreshRequirements",
          "when": "view == cuspRequirements",
          "group": "navigation@3"
        },
        {
          "command": "cusp.searchEntities",
          "when": "view == cuspEntities",
          "group": "navigation@1"
        },
        {
          "command": "cusp.clearEntitiesSearch",
          "when": "view == cuspEntities && cusp.entitiesFiltered",
          "group": "navigation@2"
        },
        {
          "command": "cusp.refreshEntities",
          "when": "view == cuspEntities",
          "group": "navigation@3"
        },
        {
          "command": "cusp.refreshTests",
          "when": "view == cuspTests",
          "group": "navigation"
        }
      ],
      "editor/title": [
        {
          "command": "cusp.specDocBack",
          "when": "activeWebviewPanelId == cuspSpecDoc",
          "group": "navigation@1"
        },
        {
          "command": "cusp.specDocForward",
          "when": "activeWebviewPanelId == cuspSpecDoc",
          "group": "navigation@2"
        }
      ],
      "view/item/context": [
        {
          "command": "cusp.reviewChangeset",
          "when": "view == cuspChangesets && (viewItem == cuspChangeset || viewItem == cuspChangesetMerged)",
          "group": "inline@1"
        },
        {
          "command": "cusp.setVerdict",
          "when": "view == cuspChangesets && viewItem == cuspChangeset",
          "group": "inline@2"
        },
        {
          "command": "cusp.submitChangeset",
          "when": "view == cuspChangesets && viewItem == cuspChangeset",
          "group": "1_lifecycle@1"
        },
        {
          "command": "cusp.mergeChangeset",
          "when": "view == cuspChangesets && viewItem == cuspChangeset",
          "group": "1_lifecycle@2"
        },
        {
          "command": "cusp.abandonChangeset",
          "when": "view == cuspChangesets && viewItem == cuspChangeset",
          "group": "1_lifecycle@3"
        }
      ],
      "comments/commentThread/context": [
        {
          "command": "cusp.review.reply",
          "when": "commentController == cusp-review",
          "group": "inline"
        }
      ],
      "comments/commentThread/title": [
        {
          "command": "cusp.review.resolveThread",
          "when": "commentController == cusp-review && commentThread == unresolved",
          "group": "inline@1"
        },
        {
          "command": "cusp.review.reopenThread",
          "when": "commentController == cusp-review && commentThread == resolved",
          "group": "inline@1"
        }
      ]
    },
    "configuration": {
      "title": "Cusp",
      "properties": {
        "cusp.cliPath": {
          "type": "string",
          "default": "cusp",
          "markdownDescription": "Path to the `cusp` CLI binary. Leave as `cusp` to use the one on `PATH`."
        },
        "cusp.workspaceFolder": {
          "type": "string",
          "default": "",
          "markdownDescription": "Absolute path to the Cusp workspace (the directory that contains `.cusp`). When empty, the first open workspace folder is used."
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run package",
    "compile": "node esbuild.js",
    "watch": "node esbuild.js --watch",
    "package": "node esbuild.js --production",
    "check-types": "tsc --noEmit",
    "vsce:package": "vsce package"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/vscode": "^1.95.0",
    "@vscode/vsce": "^3.2.0",
    "esbuild": "^0.24.0",
    "typescript": "^5.6.0"
  }
}
